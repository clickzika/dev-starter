# ═══════════════════════════════════════════════════════════
# GLOBAL SECRETS — ~/.claude/.env
# ═══════════════════════════════════════════════════════════
# Shared across ALL projects. Never commit this file.
# Copy this file: cp .env.example .env  → then fill in values.
#
# These tokens are used by dev-starter to auto-create GitHub repos
# and Notion boards for every new project.
# ═══════════════════════════════════════════════════════════

# ─── GitHub ───────────────────────────────────────────────

# YOUR GITHUB USERNAME (not a token! just your username)
# Example: johndoe, mycompany
# Find it: go to github.com → top-right profile → your username
GITHUB_USERNAME=

# GitHub Personal Access Token (starts with ghp_)
# If you already ran `gh auth login`, you can leave this blank.
# Otherwise: github.com/settings/tokens → Generate → scopes: repo
GITHUB_TOKEN=

# ─── Notion ───────────────────────────────────────────────

# Notion Integration API Key (starts with ntn_ or secret_)
# 1. Go to https://www.notion.so/my-integrations
# 2. Click "+ New integration" → name it (e.g. "Claude Agent")
# 3. Copy the "Internal Integration Secret"
# 4. In Notion sidebar, open ANY page → click "..." → "Add connections" → select your integration
#    (The agent needs access to at least one page to auto-create project boards)
NOTION_API_KEY=

# ─── Projects Root (where new project folders are created) ─
# Default: ~/Projects
# Each project creates a subfolder here: ~/Projects/MyProject/
PROJECTS_ROOT=~/Projects
