{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DEVSTARTER_HOOKS_DIR}/session-start.js\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DEVSTARTER_HOOKS_DIR}/pre-compact.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DEVSTARTER_HOOKS_DIR}/post-edit-accumulator.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DEVSTARTER_HOOKS_DIR}/stop-format-typecheck.js\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DEVSTARTER_HOOKS_DIR}/stop-check-console-log.js\""
          }
        ]
      }
    ]
  }
}
