{
  "mcpServers": {
    "mssql": {
      "command": "npx",
      "args": ["-y", "mcp-server-mssql"],
      "env": {
        "MSSQL_SERVER": "${MSSQL_SERVER}",
        "MSSQL_DATABASE": "${MSSQL_DATABASE}",
        "MSSQL_USER": "${MSSQL_USER}",
        "MSSQL_PASSWORD": "${MSSQL_PASSWORD}",
        "MSSQL_PORT": "${MSSQL_PORT:-1433}",
        "MSSQL_ENCRYPT": "${MSSQL_ENCRYPT:-true}"
      }
    }
  }
}
