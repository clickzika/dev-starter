# .project.env — Project Tool Configuration
# Copy this to your project root and edit for your project.
# All /build, /feature, /fix commands read this file.

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# VERSION CONTROL
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Options: github | gitlab | bitbucket | azure-devops | svn | none
VCS_TYPE=github

# For GitHub:
# GITHUB_REPO=username/repo-name

# For GitLab:
# GITLAB_URL=https://gitlab.com
# GITLAB_PROJECT=group/repo-name

# For Bitbucket:
# BITBUCKET_WORKSPACE=workspace
# BITBUCKET_REPO=repo-name

# For Azure DevOps:
# AZURE_ORG=https://dev.azure.com/org
# AZURE_PROJECT=project-name
# AZURE_REPO=repo-name

# For SVN:
# SVN_URL=https://svn.company.com/repos/project
# SVN_TRUNK=trunk
# SVN_BRANCHES=branches
# SVN_TAGS=tags

# For none: no version control commands will run

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# BRANCHING STRATEGY
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Options: gitflow | trunk | simple | svn-standard
BRANCH_STRATEGY=gitflow

# gitflow:    develop → feature/xxx → PR → develop → main
# trunk:      main → feature/xxx → PR → main
# simple:     main only, commit directly
# svn-standard: trunk → branches/feature-xxx → merge → trunk

# Main branch name (default: main for git, trunk for svn)
MAIN_BRANCH=main

# Development branch (gitflow only)
DEV_BRANCH=develop

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PROJECT MANAGEMENT
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Options: notion | github-issues | gitlab-issues | jira | azure-boards | trello | linear | none
PM_TYPE=notion

# For Notion:
# NOTION_DATABASE_ID=xxx
# NOTION_BOARD_URL=https://notion.so/xxx

# For Jira:
# JIRA_URL=https://company.atlassian.net
# JIRA_PROJECT=PROJ
# JIRA_API_TOKEN=xxx

# For Azure Boards:
# (uses same AZURE_ORG and AZURE_PROJECT from VCS section)

# For Trello:
# TRELLO_BOARD_ID=xxx
# TRELLO_API_KEY=xxx
# TRELLO_TOKEN=xxx

# For Linear:
# LINEAR_TEAM=xxx
# LINEAR_API_KEY=xxx

# For none: no task tracking commands will run

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CI/CD
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Options: github-actions | gitlab-ci | jenkins | azure-pipelines | none
CI_TYPE=github-actions

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SECRETS BACKEND
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Options: env-file | aws-secrets-manager | azure-keyvault | gcp-secret-manager | vault
SECRETS_BACKEND=env-file

# For AWS Secrets Manager:
# SECRETS_BACKEND_REGION=us-east-1
# Setup: ~/.claude/templates/secrets/aws-secrets-setup.md

# For Azure Key Vault:
# SECRETS_BACKEND_URL=https://my-vault.vault.azure.net
# Setup: ~/.claude/templates/secrets/azure-keyvault-setup.md

# For GCP Secret Manager:
# SECRETS_BACKEND_REGION=us-central1
# Setup: ~/.claude/templates/secrets/gcp-secretmanager.md

# For HashiCorp Vault:
# SECRETS_BACKEND_URL=https://vault.company.com:8200
# Setup: ~/.claude/templates/secrets/vault-setup.md

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI PROVIDER
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Options: claude | litellm | openai | gemini | local
AI_PROVIDER=claude
# For LiteLLM proxy: AI_PROVIDER=litellm, AI_PROVIDER_URL=http://localhost:4000
# Setup: ~/.claude/templates/litellm/provider-setup.md

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TECH STACK
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
FRONTEND=react
BACKEND=python
DATABASE=mongodb
LANGUAGE=typescript
