# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# VERSION CONTROL
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Options: github | gitlab | bitbucket | azure-devops | svn | none
VCS_TYPE=github

# For GitHub:
# GITHUB_REPO=username/repo-name

# For GitLab:
# GITLAB_URL=https://gitlab.com
# GITLAB_PROJECT=group/repo-name

# For Bitbucket:
# BITBUCKET_WORKSPACE=workspace
# BITBUCKET_REPO=repo-name

# For Azure DevOps:
# AZURE_ORG=https://dev.azure.com/org
# AZURE_PROJECT=project-name
# AZURE_REPO=repo-name

# For SVN:
# SVN_URL=https://svn.company.com/repos/project
# SVN_TRUNK=trunk
# SVN_BRANCHES=branches
# SVN_TAGS=tags

# For none: no version control commands will run

# ── Secondary VCS (mirror / archive) ──────────────
# Up to 2 secondary VCS targets. Changes are pushed here after primary merge.
# Options: github | gitlab | bitbucket | azure-devops | svn | none
VCS_SECONDARY_1=none
VCS_SECONDARY_2=none

# Branches to mirror to secondary VCS (space-separated)
VCS_SYNC_BRANCHES=main develop

# Secondary VCS connection details (fill whichever VCS_SECONDARY you chose):

# GitLab mirror:
# GITLAB_REMOTE_URL=https://gitlab.com/group/repo.git
# GITLAB_TOKEN=glpat-...        ← store in .env (not here)

# GitHub mirror:
# GITHUB_MIRROR_REPO=repo-name  ← just the repo name, username from .env

# Bitbucket mirror:
# BITBUCKET_WORKSPACE=workspace
# BITBUCKET_REPO=repo-name

# SVN bridge (git-svn):
# SVN_URL=https://svn.company.com/repos/project
# SVN_TRUNK=trunk
# SVN_BRANCHES=branches
# SVN_TAGS=tags

# Azure DevOps mirror:
# AZURE_ORG=https://dev.azure.com/org
# AZURE_PROJECT=project-name
# AZURE_REPO=repo-name

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# BRANCHING STRATEGY
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Options: gitflow | trunk | simple | svn-standard
BRANCH_STRATEGY=gitflow

# gitflow:    develop → feature/xxx → PR → develop → main
# trunk:      main → feature/xxx → PR → main
# simple:     main only, commit directly
# svn-standard: trunk → branches/feature-xxx → merge → trunk

# Main branch name (default: main for git, trunk for svn)
MAIN_BRANCH=main

# Development branch (gitflow only)
DEV_BRANCH=develop

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PROJECT MANAGEMENT
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Options: notion | github-issues | gitlab-issues | jira | azure-boards | trello | linear | none
PM_TYPE=notion

# For Notion:
# NOTION_DATABASE_ID=xxx
# NOTION_BOARD_URL=https://notion.so/xxx

# For Jira:
# JIRA_URL=https://company.atlassian.net   ← no trailing slash
# JIRA_PROJECT=PROJ                         ← project key (e.g. SHOP, AUTH)
# JIRA_BOARD_ID=1                           ← from Jira board URL
# JIRA_SPRINT_ID=                           ← current active sprint ID
# JIRA_DEFAULT_ISSUE_TYPE=Story             ← Story | Task | Bug | Epic
# JIRA_STORY_POINTS_FIELD=customfield_10016 ← discover via PROC-JR field lookup
# JIRA_EMAIL=                               ← also set in ~/.claude/.env
# (JIRA_API_TOKEN goes in ~/.claude/.env — never here)

# For Azure Boards:
# (uses same AZURE_ORG and AZURE_PROJECT from VCS section)

# For Trello:
# TRELLO_BOARD_ID=xxx
# TRELLO_API_KEY=xxx
# TRELLO_TOKEN=xxx

# For Linear:
# LINEAR_TEAM=xxx
# LINEAR_API_KEY=xxx

# For none: no task tracking commands will run

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
